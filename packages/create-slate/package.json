{
  "name": "create-slate",
  "version": "0.0.1-alpha.3",
  "type": "module",
  "preparePublishConfig": {
    "target": "npm",
    "package": {
      "private": "allow"
    },
    "metadata": {
      "remove": [
        "private",
        "scripts",
        "devDependencies",
        "preparePublishConfig"
      ]
    }
  },
  "bin": {
    "create-slate": "src/index.mjs"
  },
  "files": [
    "README.md",
    "src"
  ],
  "scripts": {
    "check": "node --check src/index.mjs"
  },
  "devDependencies": {
    "@slate/cli": "workspace:^",
    "@slate/kit": "workspace:^"
  },
  "engines": {
    "node": ">=18"
  }
}
