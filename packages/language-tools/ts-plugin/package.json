{
  "name": "@slate/ts-plugin",
  "version": "0.0.1-alpha.5",
  "type": "module",
  "private": true,
  "preparePublishConfig": {
    "package": {
      "private": "allow"
    },
    "metadata": {
      "remove": [
        "private",
        "scripts",
        "devDependencies",
        "preparePublishConfig"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "types": "./src/index.ts",
  "dependencies": {
    "@slate/compiler": "workspace:^"
  },
  "devDependencies": {
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0 <7.0.0"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "snapshot:language-service": "tsx scripts/run-language-service-fixtures.ts",
    "snapshot:shared-host": "tsx scripts/snapshot-shared-host.ts",
    "snapshot:component-types": "tsx scripts/snapshot-component-types.ts",
    "test": "bun run snapshot:language-service && bun run snapshot:shared-host && bun run snapshot:component-types"
  }
}
