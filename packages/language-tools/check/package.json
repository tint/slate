{
  "name": "@slate/check",
  "version": "0.0.1-alpha.1",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "types": "./dist/index.d.mts",
  "dependencies": {
    "@slate/compiler": "^0.0.1-alpha.1",
    "@slate/ts-plugin": "^0.0.1-alpha.1",
    "typescript": "^5.8.0"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --out-dir dist --clean",
    "check": "tsc --noEmit",
    "snapshot:check": "tsx scripts/snapshot-check.ts",
    "test": "bun run snapshot:check"
  }
}
