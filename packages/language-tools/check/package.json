{
  "name": "@slate/check",
  "version": "0.0.1-alpha.5",
  "type": "module",
  "private": true,
  "preparePublishConfig": {
    "package": {
      "private": "allow"
    },
    "metadata": {
      "remove": [
        "private",
        "scripts",
        "devDependencies",
        "preparePublishConfig"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "types": "./src/index.ts",
  "dependencies": {
    "@slate/compiler": "workspace:^",
    "@slate/ts-plugin": "workspace:^",
    "typescript": "catalog:"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "snapshot:check": "tsx scripts/snapshot-check.ts",
    "test": "bun run snapshot:check"
  }
}
