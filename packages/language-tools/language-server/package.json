{
  "name": "@slate/language-server",
  "version": "0.0.1-alpha.5",
  "type": "module",
  "private": true,
  "preparePublishConfig": {
    "package": {
      "private": "allow"
    },
    "metadata": {
      "remove": [
        "private",
        "scripts",
        "devDependencies",
        "preparePublishConfig"
      ]
    }
  },
  "bin": {
    "slate-language-server": "./src/index.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "types": "./src/index.ts",
  "dependencies": {
    "@slate/check": "workspace:^",
    "@slate/compiler": "workspace:^",
    "@slate/ts-plugin": "workspace:^",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vscode-languageserver": "catalog:",
    "vscode-languageserver-textdocument": "catalog:",
    "vscode-uri": "catalog:"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "snapshot:lsp": "tsx scripts/run-lsp-fixtures.ts",
    "test": "bun run snapshot:lsp"
  }
}
