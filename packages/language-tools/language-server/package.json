{
  "name": "@slate/language-server",
  "version": "0.0.1-alpha.2",
  "type": "module",
  "private": true,
  "bin": {
    "slate-language-server": "./dist/index.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "types": "./dist/index.d.mts",
  "dependencies": {
    "@slate/check": "^0.0.1-alpha.2",
    "@slate/compiler": "^0.0.1-alpha.2",
    "@slate/ts-plugin": "^0.0.1-alpha.2",
    "typescript": "^5.8.0",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.0.8"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --out-dir dist --clean",
    "check": "tsc --noEmit",
    "snapshot:lsp": "tsx scripts/run-lsp-fixtures.ts",
    "test": "bun run snapshot:lsp"
  }
}
