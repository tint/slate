{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node", "vitest"]
  },
  "include": ["src/**/*.ts", "fixtures/**/*.ts", "vitest.config.ts"]
}
