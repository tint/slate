{
  "name": "@slate/test",
  "version": "0.0.1-alpha.4",
  "type": "module",
  "private": true,
  "preparePublishConfig": {
    "package": {
      "private": "allow"
    },
    "metadata": {
      "remove": [
        "private",
        "scripts",
        "devDependencies",
        "preparePublishConfig"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "types": "./src/index.ts",
  "dependencies": {
    "@slate/kit": "workspace:^",
    "@slate/vite": "workspace:^",
    "vite": "catalog:"
  },
  "devDependencies": {
    "vitest": "catalog:",
    "typescript": "catalog:"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest run"
  }
}
