{
  "name": "@slate/compiler",
  "version": "0.0.1-alpha.4",
  "type": "module",
  "private": true,
  "preparePublishConfig": {
    "package": {
      "private": "allow"
    },
    "metadata": {
      "remove": [
        "private",
        "scripts",
        "devDependencies",
        "preparePublishConfig"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "types": "./src/index.ts",
  "dependencies": {
    "typescript": "catalog:"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "snapshot:parser": "tsx scripts/snapshot-parser.ts",
    "snapshot:analyzer": "tsx scripts/snapshot-analyzer.ts",
    "snapshot:codegen": "tsx scripts/snapshot-codegen.ts",
    "test": "bun run snapshot:parser && bun run snapshot:analyzer && bun run snapshot:codegen && bun run test:render",
    "test:render": "tsx scripts/run-render-fixtures.ts"
  }
}
