{
  "name": "@slate/kit",
  "version": "0.0.1-alpha.4",
  "type": "module",
  "private": true,
  "preparePublishConfig": {
    "package": {
      "private": "allow"
    },
    "metadata": {
      "remove": [
        "private",
        "scripts",
        "devDependencies",
        "preparePublishConfig"
      ]
    }
