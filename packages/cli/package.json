{
  "name": "@slate/cli",
  "version": "0.0.1-alpha.1",
  "type": "module",
  "private": true,
  "bin": {
    "slate": "./dist/index.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./config": {
      "types": "./dist/config.d.mts",
      "import": "./dist/config.mjs",
      "default": "./dist/config.mjs"
    }
  },
  "types": "./dist/index.d.mts",
  "dependencies": {
    "@slate/check": "^0.0.1-alpha.1",
    "@slate/compiler": "^0.0.1-alpha.1",
    "@slate/kit": "^0.0.1-alpha.1",
    "@slate/vite": "^0.0.1-alpha.1",
    "cac": "^7.0.0",
    "tsx": "^4.20.0"
  },
  "scripts": {
    "build": "tsdown src/index.ts src/commands.ts src/config.ts --format esm --dts --out-dir dist --clean",
    "check": "tsc --noEmit",
    "test": "tsx scripts/run-fixtures.ts"
  }
}
