{
  "name": "@slate/cli",
  "version": "0.0.1-alpha.7",
  "type": "module",
  "private": true,
  "preparePublishConfig": {
    "package": {
      "private": "allow"
    },
    "metadata": {
      "remove": [
        "private",
        "scripts",
        "devDependencies",
        "preparePublishConfig"
      ]
    }
  },
  "bin": {
    "slate": "./src/bin.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./config": {
      "types": "./src/config.ts",
      "import": "./src/config.ts",
      "default": "./src/config.ts"
    }
  },
  "types": "./src/index.ts",
  "dependencies": {
    "@slate/check": "workspace:^",
    "@slate/compiler": "workspace:^",
    "@slate/kit": "workspace:^",
    "@slate/vite": "workspace:^",
    "cac": "^7.0.0",
    "tsx": "catalog:"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "tsx scripts/run-fixtures.ts"
  },
  "engines": {
    "node": ">=22.18"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
